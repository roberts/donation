{% extends 'base.html.twig' %}

{% block title %}Donation index{% endblock %}

{% block body %}
    <h1>Donation index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>PaymentIntentId</th>
                <th>Amount</th>
                <th>Email</th>
                <th>Title</th>
                <th>FirstName</th>
                <th>LastName</th>
                <th>FilingStatus</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for donation in donations %}
            <tr>
                <td>{{ donation.id }}</td>
                <td>{{ donation.paymentIntentId }}</td>
                <td>{{ donation.amount }}</td>
                <td>{{ donation.email }}</td>
                <td>{{ donation.title }}</td>
                <td>{{ donation.firstName }}</td>
                <td>{{ donation.lastName }}</td>
                <td>{{ donation.filingStatus }}</td>
                <td>
                    <a href="{{ path('app_donation_show', {'id': donation.id}) }}">show</a>
                    <a href="{{ path('app_donation_edit', {'id': donation.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_donation_new') }}">Create new</a>
{% endblock %}
