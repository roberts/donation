APP_NAME="IBE Foundation"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://ibefoundation.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ibe
DB_USERNAME=root
DB_PASSWORD=root

STRIPE_KEY=pk_live_XXXXXXXXX
STRIPE_SECRET=sk_live_XXXXXXXXX

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"



# Legacy Database Configuration
DATABASE_URL=mysql://username:password@127.0.0.1:3306/database_name

# AWS SES Configuration for Email Sending
AWS_SES_HOST=email-smtp.us-west-2.amazonaws.com
AWS_SES_PORT=2587
AWS_SES_ENCRYPTION=tls
AWS_SES_USERNAME=YOUR_AWS_SES_USERNAME_HERE
AWS_SES_PASSWORD=YOUR_AWS_SES_PASSWORD_HERE
